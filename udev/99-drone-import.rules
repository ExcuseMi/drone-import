# Trigger drone-import on USB storage insertion.
# HDZero BoxPro uses FAT32; DJI cameras use exFAT.
# The service mounts the device and identifies the camera by DCIM folder structure.

ACTION=="add", SUBSYSTEM=="block", ENV{DEVTYPE}=="partition", ENV{ID_FS_TYPE}=="vfat",  ENV{ID_BUS}=="usb", TAG+="systemd", ENV{SYSTEMD_WANTS}+="drone-import@%k.service"
ACTION=="add", SUBSYSTEM=="block", ENV{DEVTYPE}=="partition", ENV{ID_FS_TYPE}=="exfat", ENV{ID_BUS}=="usb", TAG+="systemd", ENV{SYSTEMD_WANTS}+="drone-import@%k.service"
ACTION=="add", SUBSYSTEM=="block", ENV{DEVTYPE}=="disk",      ENV{ID_FS_TYPE}=="exfat", ENV{ID_BUS}=="usb", TAG+="systemd", ENV{SYSTEMD_WANTS}+="drone-import@%k.service"
